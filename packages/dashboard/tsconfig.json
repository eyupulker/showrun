{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "jsx": "react-jsx",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "incremental": true,
    "composite": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "declaration": true
  },
  "include": [
    "src/**/*"
  ],
  "references": [
    {
      "path": "../core"
    },
    {
      "path": "../harness"
    },
    {
      "path": "../mcp-server"
    }
  ]
}
