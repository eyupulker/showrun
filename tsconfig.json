{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "lib": [
      "ES2022"
    ],
    "moduleResolution": "node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "incremental": true,
    "composite": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },
  "exclude": [
    "node_modules",
    "dist",
    "runs",
    "**/*.js",
    "**/*.d.ts",
    "**/ui/**"
  ],
  "references": [
    {
      "path": "packages/browser-inspector-mcp"
    },
    {
      "path": "packages/core"
    },
    {
      "path": "packages/dashboard"
    },
    {
      "path": "packages/harness"
    },
    {
      "path": "packages/mcp-server"
    },
    {
      "path": "packages/showrun"
    },
    {
      "path": "packages/taskpack-editor-mcp"
    }
  ]
}
